# Python Cache
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/

# Virtual Environments
.venv/
venv/
ENV/
env/

# Environment Variables & Keys
.env*
!.env.example

# Databases & Local Storage (Avoid committing heavy binary vectors)
db/
*.db
*.sqlite

# Large Documentations / RAG Docs (Do not commit 1GB+ of documentation)
docs/

# IDE & Editor Settings
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# OS Files
.DS_Store
Thumbs.db

# Project-specific Temporary Files
scratch/
session_checkpoint.md
logs/*
!logs/.gitkeep

# Agent System Prompt
.agents/
.claude/
AGENTS

# Graphify Output (Do not commit large graph outputs)
graphify-out/
